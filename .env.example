# Public runtime config
NUXT_PUBLIC_BASE_URL=http://localhost:3000
NUXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_123

# Stripe
NUXT_STRIPE_SECRET_KEY=sk_test_123
NUXT_STRIPE_WEBHOOK_SECRET=whsec_123

# Printful
NUXT_PRINTFUL_API_KEY=pfk_123

# Cloudflare R2
NUXT_CF_ACCOUNT_ID=your_cloudflare_account_id
NUXT_R2_ACCESS_KEY_ID=your_r2_access_key_id
NUXT_R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
NUXT_R2_BUCKET_NAME=printapoint-orders
NUXT_R2_PUBLIC_URL=https://pub-xxxxxxxxxxxxxxxx.r2.dev

# Printful variant IDs for poster sizes
NUXT_PRINTFUL_VARIANT_18X24=
NUXT_PRINTFUL_VARIANT_24X36=
NUXT_PRINTFUL_VARIANT_30X40=

# Optional retail price overrides (in cents)
NUXT_PRICE_18X24=8900
NUXT_PRICE_24X36=12900
NUXT_PRICE_30X40=16900

# Optional comma-separated country code override. If empty, app fetches countries from Printful.
# Example: US,CA,GB,DE,FR
NUXT_ALLOWED_COUNTRIES=
